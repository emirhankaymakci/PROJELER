yazdir "AnadoluKod Diline Hosgeldiniz!"

koy yas = 15
koy bitis = 18

yazdir "Simdiki Yasin:"
yazdir yas

dongu yas < bitis oldukca
    yazdir "Bir yas daha buyudun. Yeni Yasin:"
    koy yas = yas + 1
    yazdir yas
bitti

eger yas == 18 ise
    yazdir "Tebrikler Resit Oldun!"
bitti

yazdir "AnadoluKod Matematik Testi: 10 + 20 / 2 ="
yazdir 10 + 20 / 2

yazdir "Program Sonlandi."
